{
  "jsPlugins": [
    { "name": "sonarjs", "specifier": "eslint-plugin-sonarjs" },
    { "name": "ironlint-custom", "specifier": "./strict-custom-rules.mjs" }
  ],
  "rules": {
    "curly": ["error", "all"],
    "eqeqeq": ["error", "always"],
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "no-eval": "error",
    "no-new-func": "error",
    "no-warning-comments": [
      "error",
      { "terms": ["todo", "fixme", "hack", "xxx"], "location": "anywhere" }
    ],

    "complexity": ["error", 14],
    "max-params": ["error", 4],
    "max-lines": ["error", { "max": 600, "skipBlankLines": true, "skipComments": true }],
    "max-lines-per-function": [
      "error",
      { "max": 250, "skipBlankLines": true, "skipComments": true, "IIFEs": true }
    ],

    "no-else-return": "error",
    "no-nested-ternary": "error",
    "no-implicit-coercion": "error",
    "no-unneeded-ternary": "error",
    "no-useless-return": "error",
    "no-param-reassign": "error",

    "no-unused-vars": "error",
    "no-unreachable": "error",
    "no-unused-labels": "error",
    "no-fallthrough": "error",

    "default-case": "error",
    "default-case-last": "error",

    "prefer-const": "error",
    "no-duplicate-imports": "error",

    "sonarjs/unused-import": "error",
    "sonarjs/no-dead-store": "error",
    "sonarjs/no-identical-conditions": "error",
    "sonarjs/no-duplicated-branches": "error",
    "sonarjs/no-ignored-return": "error",

    "import/no-cycle": "error",
    "import/no-relative-parent-imports": "error",
    "oxc/no-barrel-file": ["error", { "threshold": 0 }],

    "ironlint-custom/no-aliased-re-export": "error",
    "ironlint-custom/no-reexports": "error",
    "ironlint-custom/no-default-export-in-src": "error",
    "typescript/consistent-type-imports": "error",
    "ironlint-custom/prefer-types-file": "error",
    "ironlint-custom/hook-file-placement": "error",
    "ironlint-custom/test-file-placement": "error"
  }
}
