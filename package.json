{
  "name": "ironlint",
  "version": "0.1.0",
  "description": "Strict, opinionated shared Oxlint/Oxfmt config for React projects",
  "type": "module",
  "license": "MIT",
  "files": [
    "bin",
    "oxlint",
    "oxfmt",
    "README.md"
  ],
  "bin": {
    "ironlint": "bin/cli.mjs"
  },
  "exports": {
    "./oxlint/strict-react.json": "./oxlint/strict-react.json",
    "./oxfmt/strict": "./oxfmt/strict.mjs"
  },
  "dependencies": {
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-testing-library": "^7.16.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "oxlint",
    "oxfmt",
    "react",
    "lint",
    "formatter",
    "opinionated"
  ]
}
